# ATS Platform Environment Variables
# Copy this file to .env in the root directory (D:\NLP\.env)

# Database Configuration (Leave these as default for local docker-compose)
DATABASE_URL=postgresql://postgres:root@db:5432/ats_db
REDIS_URL=redis://redis:6379/0

# LLM Engine API Key
# Go to https://console.groq.com/keys to get your free API key
GROQ_API_KEY=your_actual_groq_api_key_here
